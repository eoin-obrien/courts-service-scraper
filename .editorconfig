root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space

[*.py]
indent_size = 4
max_line_length = 88

[*.{yml,yaml,toml,json,md,cff}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false  # trailing spaces are meaningful in Markdown

[Makefile]
indent_style = tab
